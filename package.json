{
  "name": "aegis",
  "version": "0.1.0",
  "description": "A strict multi-agent swarm orchestration framework",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aegis": "dist/index.js"
  },
  "files": [
    "dist",
    "olympus/dist"
  ],
  "workspaces": [
    "olympus"
  ],
  "scripts": {
    "build": "npm run build:node && npm run build:olympus",
    "build:node": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc --project tsconfig.json",
    "dev": "tsx src/index.ts",
    "mock:seed": "tsx src/mock-run/seed-mock-run.ts",
    "start": "node dist/index.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "tsc --project tsconfig.tests.json --noEmit && npm run lint --workspace olympus",
    "build:olympus": "npm run build --workspace olympus",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "ai",
    "agents",
    "swarm",
    "orchestrator",
    "pi",
    "beads"
  ],
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
